# Copie para .env.local (não commite). Modo live: dados vêm do Google a cada pedido + polling no browser.

# URL dos dados (relativa ao site). Live usa a API serverless no Vercel e o middleware no vite dev.
VITE_DASHBOARD_DATA_URL=/api/dashboard-bundle

# Atualização automática no browser (ms). Ex.: 60000 = 1 min. Use 0 para só ao abrir/recarregar.
VITE_DASHBOARD_POLL_MS=60000

# --- Servidor / API apenas (NUNCA prefixo VITE_ — não ir para o bundle do cliente) ---
# Opção A — ficheiro local (recomendado para dev; não commite o .json da Google):
# GOOGLE_SERVICE_ACCOUNT_FILE=/Users/voce/caminho/conta-servico.json
# Opção B — colar JSON inteiro (Vercel costuma usar esta):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# GOOGLE_SHEETS_SPREADSHEET_ID=1b__ZMvvF4JM6v2vSPF-2iIfItZTOgrlASixP5yafKW4
